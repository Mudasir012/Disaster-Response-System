# ─── Database ───
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/disaster-tracker
REDIS_URL=redis://localhost:6379

# ─── Auth ───
JWT_SECRET=your-64-char-random-hex-here

# ─── AI (Claude) ───
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── External API Keys ───
TWITTER_BEARER_TOKEN=AAAA...
NEWS_API_KEY=abc123...
RESEND_API_KEY=re_...

# ─── External API URLs (optional overrides) ───
TWITTER_API_URL=https://api.twitter.com/2/tweets/search/recent
TWITTER_QUERY=earthquake OR flood OR wildfire OR cyclone OR tsunami -has:links
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_QUERY=earthquake OR flood OR wildfire OR cyclone OR tsunami OR hurricane OR tornado OR volcanic eruption
NOAA_API_URL=https://api.weather.gov/alerts/active
USGS_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
GDACS_API_URL=https://gdacs.org/xml/rss.xml
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
RESEND_API_URL=https://api.resend.com/emails

# ─── Email ───
EMAIL_FROM_ADDRESS=DisasterTracker <alerts@disastertracker.app>
NOMINATIM_EMAIL=you@email.com

# ─── App ───
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
USER_AGENT=DisasterTracker/1.0

# ─── Tuning ───
SYNC_INTERVAL_MS=120000
AI_CONFIDENCE_THRESHOLD=0.7
MAX_INCIDENTS_GEOJSON=500

# ─── Seeding (dev only) ───
SEED_ADMIN_EMAIL=admin@disastertracker.app
SEED_ADMIN_PASSWORD=admin123
