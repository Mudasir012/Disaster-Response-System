# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/disastertracker

# Redis
REDIS_URL=redis://localhost:6379

# AI
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com

# Email
RESEND_API_KEY=your_resend_api_key

# Admin
JWT_SECRET=generate_a_random_64_character_hex_string_here
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_password

# Geocoding
NOMINATIM_EMAIL=your_email_for_nominatim_usage_policy

# Sync
SYNC_INTERVAL_MINUTES=15
AI_CONFIDENCE_THRESHOLD=0.7
MAX_GEOJSON_INCIDENTS=500
