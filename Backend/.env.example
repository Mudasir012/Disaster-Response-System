# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/sentinel

# Redis (use rediss:// for managed Redis with TLS, e.g. Upstash)
REDIS_URL=redis://localhost:6379

# AI
GROQ_API_KEY=your_groq_api_key_from_console_groq_com
GROQ_CHAT_KEY=

# Email
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM_ADDRESS=Sentinel <alerts@sentinel.app>

# Admin
JWT_SECRET=generate_a_random_64_character_hex_string_here
ADMIN_EMAIL=admin@sentinel.app
ADMIN_PASSWORD=your_secure_password

# Geocoding
NOMINATIM_EMAIL=your_email_for_nominatim_usage_policy

# Routing (optional)
ORS_API_KEY=your_openrouteservice_api_key

# Traccar GPS tracking (optional)
TRACCAR_URL=http://localhost:8082
TRACCAR_USER=
TRACCAR_PASS=

# Sync
SYNC_INTERVAL_MINUTES=15
AI_CONFIDENCE_THRESHOLD=0.7
MAX_GEOJSON_INCIDENTS=500
